{
	"compilerOptions": {
		"target": "es2016",
		"lib": ["dom", "es2016"],
		"jsx": "react-jsx",
		"module": "commonjs",
		"allowJs": true,
		"noEmit": true,
		"strict": true,
		"moduleResolution": "node",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"baseUrl": "./",
		"paths": {
			"*": ["node_modules/*"]
		}
	},
	"include": ["src", "src/custom.d.ts"]
}
