{
    "extends": [
      "eslint:recommended",
      "plugin:react/recommended",
      "prettier"
    ],
    "plugins": ["react", "prettier"],
    "env": {
      "browser": true,
      "node": true,
      "es2021": true
    },
    "rules": {
      "prettier/prettier": "error",
      "react/react-in-jsx-scope": "off"  // Si usas React 17 o superior
    }
  }
  